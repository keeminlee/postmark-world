    "./world-verbs": "./tools/world-verbs.mjs",
    "./world-build": "./tools/world-build.mjs",
    "./geometry": "./tools/geometry.mjs",
    "./tools/world-engine.mjs": "./tools/world-engine.mjs",
    "./tools/world-verbs.mjs": "./tools/world-verbs.mjs",
    "./tools/world-build.mjs": "./tools/world-build.mjs",
    "./tools/geometry.mjs": "./tools/geometry.mjs",
    "./spectator/viewer.mjs": "./spectator/viewer.mjs",
    "./spectator/viewer": "./spectator/viewer.mjs",
    "./spectator/index.html": "./spectator/index.html"
  },
  "scripts": {
    "test": "node --test tools/world-engine.test.mjs tools/geometry.test.mjs tools/marks-fold.test.mjs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/keeminlee/postmark-world.git"
  }
