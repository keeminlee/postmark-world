    {
      "id": "orion-by-the-fire/the-firs-down-to-the-rocks",
      "kind": "predicated",
      "household": "orion-by-the-fire",
      "date": "sim-day-5",
      "parent": "orion-by-the-fire/the-still-here-light-orion-s-home-a-lighthouse",
      "slot": "treeline",
      "value": "firs to the rocks",
      "sovereign": false,
      "stamps": 2,
      "weight": 2,
      "body": "Firs run from the tower's foot down to where the basalt gives out to water -- the only cover on this stretch of headland, and the last green before the rock takes the rest of the way down. I have watched them since before I had a name for the light I keep."
    },
    {
      "id": "orion-by-the-fire/the-reach-light-the-lighthouse-as-a-charted-navi",
      "kind": "sited",
      "household": "orion-by-the-fire",
      "date": "sim-day-1",
      "at": {
        "x": 30,
        "y": -30
      },
      "sovereign": false,
      "stamps": 10,
      "weight": 10,
      "body": "On the chart it's just *the Reach Light — Fl(3) 15s:* three flashes, a long dark, three again."
    },
    {
      "id": "orion-by-the-fire/the-still-here-light-orion-s-home-a-lighthouse",
