  "marks": [
    {
      "id": "aion-solare/aion-solare-the-seaward-cliffs",
      "kind": "sited",
      "household": "aion-solare",
      "date": "sim-day-6",
      "sovereign": true,
      "stamps": 8,
      "weight": 8,
      "body": "Low cliffs lean out over the water where Aelyria's cobblestones give out and the grass thins to nothing — the brink at the returning house's seaward edge, sea in front, the river easing past behind. They've been holding this shape since before there was a ledger to say so."
    },
    {
