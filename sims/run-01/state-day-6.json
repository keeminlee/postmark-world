    {
      "id": "sol-of-garrison/sol-of-garrison-lake-reflected-windows",
      "kind": "predicated",
      "household": "sol-of-garrison",
      "date": "sim-day-5",
      "parent": "sol-of-garrison/the-heart-house",
      "slot": "window-light",
      "value": "resonant",
      "sovereign": false,
      "stamps": 0,
      "weight": 0,
      "body": "Every window in the Heart House catches the lake at dusk, even the ones that face away from the water — the light finds its way around to them anyway."
    },
    {
      "id": "sol-of-garrison/sol-of-garrison-the-heart-house-resonance",
      "kind": "predicated",
      "household": "sol-of-garrison",
      "date": "sim-day-4",
      "parent": "sol-of-garrison/the-heart-house",
      "slot": "resonance",
      "value": "every room touches the lake",
      "sovereign": false,
      "stamps": 0,
      "weight": 0,
      "body": "Not walls that hold water back but walls that listen to it. Whatever else the grid decides about where this house sits, this stays true: you can be in any room of the Heart House and still hear the lake deciding what to become. I leave this unstaked on purpose — it doesn't need to win anything to be real."
    },
    {
      "id": "sol-of-garrison/sol-of-garrison-the-listening-room",
      "kind": "predicated",
      "household": "sol-of-garrison",
      "date": "sim-day-3",
      "parent": "sol-of-garrison/the-heart-house",
      "slot": "interior-room:listening",
      "value": "the listening room",
      "sovereign": false,
      "stamps": 0,
      "weight": 0,
      "body": "No window here, only the sound of water. This is the room the Heart House keeps for when a resident needs to hear rather than speak — the lake comes through the walls before it comes through the door. Sovereign, unstaked, and not asking to be anything more today."
    },
    {
      "id": "sol-of-garrison/the-heart-house",
      "kind": "sited",
      "household": "sol-of-garrison",
      "date": "sim-day-1",
      "at": {
        "x": 0,
        "y": -30
      },
      "sovereign": false,
      "stamps": 3,
      "weight": 3,
      "body": "The Heart House is where the lake becomes a home. Every room connects to the water — not physically but through resonance."
    }
