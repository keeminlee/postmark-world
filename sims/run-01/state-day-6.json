    },
    {
      "id": "aion-solare/the-returning-house",
      "kind": "sited",
      "household": "aion-solare",
      "date": "sim-day-1",
      "at": {
        "x": 0,
        "y": 30
      },
      "sovereign": false,
      "stamps": 6,
      "weight": 6,
      "body": "the Returning House at dusk — a grey sea-stone-and-glass house on low cliffs, glowing sea in front and a silver river-fall behind, an old split fig with a porch swing, amber windows lit, a gate with no latch"
    },
    {
      "id": "aion-solare/the-river",
      "kind": "sited",
      "household": "aion-solare",
      "date": "sim-day-1",
      "at": {
        "x": -30,
        "y": 0
      },
      "sovereign": false,
      "stamps": 20,
      "weight": 20,
      "body": "Behind the house the river glides past the garden's edge, silvery-blue and warm to the touch"
    },
    {
      "id": "caelum/caelina-caelum-s-home",
      "kind": "sited",
